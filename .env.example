# === Docker Deployment ===
# For Docker deployment, copy this file to .env and fill in real values

# Database configuration
DB_USER=payload
DB_PASSWORD=your-db-password
DB_NAME=first_myself_site

# Payload CMS secrets (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your-payload-secret
ADMIN_SECRET_TOKEN=your-admin-token
NEXTAUTH_SECRET=your-nextauth-secret

# Your domain
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_SERVER_URL=https://your-domain.com

# ============================================
# Environment Variables - Development Example
# ====================================================
#
# Copy this file to .env.local and fill in values
# DO NOT commit .env or .env.local files with sensitive data
#
# CRITICAL: For production deployment on Vercel:
# 1. Generate PAYLOAD_SECRET: openssl rand -base64 32
# 2. Generate ADMIN_SECRET_TOKEN: openssl rand -hex 32
# 3. Set PAYLOAD_INITIAL_ADMIN_EMAIL to your email
# 4. Set PAYLOAD_INITIAL_ADMIN_PASSWORD to a strong password
# 5. Configure all values in Vercel Settings → Environment Variables
# 6. NEVER commit these values to the repository

# === Required in all environments ===

# Secret key for Payload CMS JWT signing
# CRITICAL: Must be set. Generate with: openssl rand -base64 32
# NEVER use default values in production
PAYLOAD_SECRET=your-secret-key-at-least-32-characters-long

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# === Development only ===

# Authentication token for development API endpoints (/api/seed, /api/create-admin)
# Generate with: openssl rand -hex 32
# Only needed in development; not used in production
ADMIN_SECRET_TOKEN=your-admin-secret-token-here

# Initial admin credentials for first setup
# Only used when creating admin account via /api/create-admin
# NEVER use default credentials in production
PAYLOAD_INITIAL_ADMIN_EMAIL=admin@example.com
PAYLOAD_INITIAL_ADMIN_PASSWORD=admin123

# Log level
PAYLOAD_LOG_LEVEL=debug

# Node environment
NODE_ENV=development

# === Optional ===

# Enable verbose Payload logging (for troubleshooting)
# PAYLOAD_DEBUG=true
