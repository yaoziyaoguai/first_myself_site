# ============================================
# 测试环境环境变量模板
# 放置位置: 仓库根目录
#
# 使用方法:
# 1. cp .env.test.example .env.test
# 2. 编辑 .env.test，填充密钥
# 3. cd docker && docker-compose -f docker-compose.test.yml --env-file ../.env.test up -d
#
# 警告: .env.test 已加入 .gitignore，切勿提交！
# ============================================

# 数据库配置
POSTGRES_DB=payload_test
POSTGRES_USER=payload_test_user
POSTGRES_PASSWORD=change_this_to_random_password

# 数据库宿主机端口（避免冲突）
POSTGRES_PORT=5433

# Payload CMS 密钥（openssl rand -base64 32）
PAYLOAD_SECRET=your_secret_here

# NextAuth 配置
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3001

# 公共 URL（修改后需重新构建）
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# 应用端口
APP_PORT=3001
