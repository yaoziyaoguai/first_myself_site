# ============================================
# 生产环境环境变量模板 (Docker)
# 放置位置: 仓库根目录
#
# 使用方法:
# 1. cp .env.docker.prod.example .env.docker.prod
# 2. 编辑 .env.docker.prod，填入真实生产值
# 3. 确保 .env.docker.prod 已加入 .gitignore（不应提交）
#
# 警告: 此文件包含生产敏感信息，切勿提交到 Git！
# ============================================

# -------------------------------------------------
# 数据库配置 (Docker PostgreSQL)
# -------------------------------------------------
POSTGRES_DB=first_myself_site_prod
POSTGRES_USER=payload_prod
# 强随机密码（建议 32 位以上）
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_RANDOM_PASSWORD

# -------------------------------------------------
# Payload CMS 安全密钥
# 生成命令: openssl rand -base64 32
# -------------------------------------------------
PAYLOAD_SECRET=CHANGE_THIS_TO_GENERATED_SECRET

# -------------------------------------------------
# NextAuth 配置
# -------------------------------------------------
# NextAuth Secret（生成方式同上）
NEXTAUTH_SECRET=CHANGE_THIS_TO_GENERATED_SECRET

# 正式域名
NEXTAUTH_URL=https://wangjinkun333.me

# -------------------------------------------------
# 公共 URL（Next.js 构建时内联到客户端）
# 警告: 修改此值后必须重新构建镜像
# -------------------------------------------------
NEXT_PUBLIC_SERVER_URL=https://wangjinkun333.me

# -------------------------------------------------
# 可选: 首次管理员创建配置
# 仅在需要时使用 /api/create-admin（当前被禁用）
# -------------------------------------------------
# ADMIN_SECRET_TOKEN=another_random_token
# PAYLOAD_INITIAL_ADMIN_EMAIL=admin@your-domain.com
# PAYLOAD_INITIAL_ADMIN_PASSWORD=strong_initial_password
